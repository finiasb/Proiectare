<Window x:Class="Proiectie.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setări" Height="400" Width="400" Background="#1E1E1E" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="CONFIGURARE" Foreground="#007ACC" FontSize="20" Margin="0,0,0,20"/>

        <ItemsControl x:Name="MonitorsList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding DeviceName}" 
                          IsChecked="{Binding IsSelected}" 
                          Foreground="White"
                          Margin="5" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Label Content="Mărime Font Proiecție:" Foreground="White"/>
        <Slider Minimum="20" Maximum="120" Value="60" Margin="0,5,0,20"/>

        <Label Content="Culoare Fundal:" Foreground="White"/>
        <ComboBox Margin="0,5,0,20">
            <ComboBoxItem Content="Negru" IsSelected="True"/>
            <ComboBoxItem Content="Albastru"/>
        </ComboBox>

        <Button Content="SALVEAZĂ" Click="Save_Click" Height="35" Background="#28A745" Foreground="White" Margin="0,20,0,0"/>
    </StackPanel>
</Window>