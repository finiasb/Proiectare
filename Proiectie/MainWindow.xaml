
    <Window x:Class="Proiectie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d" 
        Title="Proiectie" 
        WindowState="Maximized" 
        Height="600" 
        Width="800" 
        d:DesignHeight="1080" 
        d:DesignWidth="1920" 
        Background="#252525">
    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#3F3F3F" BorderThickness="0,0,1,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <Label Content="BIBLIOTECĂ CÂNTĂRI" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>

                    <!-- BUTOANE TIP CĂUTARE -->
                    <UniformGrid Columns="2" Margin="5,0,5,10">
                        <RadioButton x:Name="rbTitlu" 
                 Content="Titlu" 
                 IsChecked="True" 
                 Foreground="White" 
                 GroupName="SearchType"
                 Checked="SearchType_Changed"/>
                        <RadioButton x:Name="rbContinut" 
                 Content="Conținut" 
                 Foreground="White" 
                 GroupName="SearchType"
                 Checked="SearchType_Changed"/>
                    </UniformGrid>

                    <TextBox x:Name="txtSearch" Height="30" Background="#3F3F3F" Foreground="White" 
                             BorderThickness="0" VerticalContentAlignment="Center" Margin="5,0"/>
                </StackPanel>

                <ListBox x:Name="lstCantari" Grid.Row="1" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" 
                         Foreground="White" DisplayMemberPath="Titlu" SelectionChanged="lstCantari_SelectionChanged">
                    <!-- ContextMenu pentru a adăuga la favorite -->
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Adaugă în Program" Click="MenuItem_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
                <Button Grid.Row="1" 
                    Content="ADaugă în Program (+)" 
                    VerticalAlignment="Bottom" 
                    Height="35" 
                    Margin="5"
                    Background="#007ACC" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="MenuItem_Click"/>
                </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="lblSelectedTitle" Text="Nicio cântare selectată" 
                       Foreground="#007ACC" FontSize="24" FontWeight="Light" Margin="0,0,0,20"/>
            <ScrollViewer Grid.Row="1">
                <ItemsControl x:Name="itemsStrofe">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,10" Background="#333" BorderThickness="1" BorderBrush="#444"
                                    Click="Strofa_Click" HorizontalContentAlignment="Stretch">
                                <StackPanel Margin="15">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="White" FontSize="18" LineHeight="25"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="2" Background="#1E1E1E" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SECȚIUNEA LIVE -->
                <StackPanel Grid.Row="0">
                    <Label Content="LIVE PE ECRAN" Foreground="#FF4500" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Border Background="Black" Height="150" CornerRadius="5" BorderBrush="#555" BorderThickness="1">
                        <TextBlock x:Name="txtLivePreview" Text="-" Foreground="White" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="10"/>
                    </Border>
                    <Button x:Name="btnToggleProjection" Content="DESCHIDE PROIECȚIA" Margin="0,10,0,5" Height="35" Background="#28A745" Foreground="White" Click="btnToggleProjection_Click"/>
                    <Button Content="ASCUNDE TEXTUL" Height="35" Background="#C0392B" Foreground="White" Click="Blackout_Click" Margin="0,0,0,20"/>
                </StackPanel>

                <!-- SECȚIUNEA FAVORITE (PROGRAM) -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="PROGRAM CÂNTĂRI (FAVORITE)" Foreground="#007ACC" FontWeight="Bold" Margin="0,10,0,0"/>
                    <ListBox x:Name="lstFavorite" Grid.Row="1" Background="#252525" BorderBrush="#333" Foreground="White" 
                             DisplayMemberPath="Titlu" SelectionChanged="lstFavorite_SelectionChanged"/>
                    <Button Grid.Row="2" Content="Șterge din Program" Click="BtnStergeFavorite_Click" Background="#444" Foreground="White" Margin="0,5,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>