<Window x:Class="Proiectie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pro-Chant Control Panel" Height="700" Width="1200" Background="#252525">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#3F3F3F" BorderThickness="0,0,1,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <Label Content="BIBLIOTECĂ CÂNTĂRI" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtSearch" Height="30" Background="#3F3F3F" Foreground="White" 
                             BorderThickness="0" VerticalContentAlignment="Center" Margin="5,0"/>
                </StackPanel>
                <ListBox x:Name="lstCantari" Grid.Row="1" Margin="0,10,0,0" 
                         Background="Transparent" BorderThickness="0" Foreground="White"
                         DisplayMemberPath="Titlu" SelectionChanged="lstCantari_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="10"/>
                            <Setter Property="Margin" Value="2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="lblSelectedTitle" Text="Nicio cântare selectată" 
                       Foreground="#007ACC" FontSize="24" FontWeight="Light" Margin="0,0,0,20"/>

            <ScrollViewer Grid.Row="1">
                <ItemsControl x:Name="itemsStrofe">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,10" Background="#333" BorderThickness="1" BorderBrush="#444"
                                    Click="Strofa_Click" HorizontalContentAlignment="Stretch">
                                <StackPanel Margin="15">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="White" FontSize="18" LineHeight="25"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="2" Background="#1E1E1E" Padding="15">
            <StackPanel>
                <Label Content="LIVE PE ECRAN" Foreground="#FF4500" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Border Background="Black" Height="180" CornerRadius="5" BorderBrush="#555" BorderThickness="1">
                    <TextBlock x:Name="txtLivePreview" Text="-" Foreground="White" 
                               TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="10"/>
                </Border>

                <Button Content="DESCHIDE PROIECȚIA" Margin="0,20,0,5" Height="40" Background="#007ACC" Foreground="White" Click="OpenProjection_Click"/>
                <Button Content="OPREȘTE PROIECȚIA"  Click="BtnCloseProjection_Click" Background="#C0392B" Foreground="White" Height="40" Margin="5"/>
                <Button Content="ASCUNDE TEXTUL (F5)" Height="40" Background="#C0392B" Foreground="White" Click="Blackout_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>